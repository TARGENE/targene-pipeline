params {
    simulation_image_version = "olivierlabayle/targene-simulations:0.2"
    targenecore_image_version = "olivierlabayle/tl-core:0.13"
    ukb_image_version = "olivierlabayle/ukbmain:0.5"
    tmle_image_version = "olivierlabayle/targeted-estimation:0.10"
    plink_image_version = "olivierlabayle/plink2:0.1.0"
    pca_image_version = "roskamsh/flashpca:0.1.0"
    base_image_version = "roskamsh/commandlinetools:0.1.2"
}

process {
    withLabel: simulation_image {
        container = params.simulation_image_version
    }
    withLabel: targenecore_image {
        container = params.targenecore_image_version
    }
    withLabel: ukb_image {
        container = params.ukb_image_version 
    }
    withLabel: tmle_image {
        container = params.tmle_image_version
    }
    withLabel: plink_image {
        container = params.plink_image_version 
    }
    withLabel: pca_image {
        container = params.pca_image_version 
    } 
}
