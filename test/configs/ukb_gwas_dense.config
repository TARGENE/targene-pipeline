includeConfig 'ukb.config'

params {
    TRAITS_DATASET = "${projectDir}/test/assets/dataset.csv"
    QC_FILE = "${projectDir}/test/assets/qc_file.csv"
    ESTIMANDS_CONFIG = "${projectDir}/test/assets/gwas_config.yaml"
    UKB_WITHDRAWAL_LIST = "${projectDir}/test/assets/withdrawal_list.txt"
    UKB_CONFIG = "${projectDir}/test/assets/ukbconfig_gwas.yaml"
    DENSE_MAPPING_FILE = "${projectDir}/test/assets/prioritised_snps.txt"
    WINDOW_SIZE = 500000
}

process {
    memory = '4G'

    withLabel: bigmem {
        memory = '4G'
    }

    withLabel: multithreaded {
        cpus = 1
    }
}
